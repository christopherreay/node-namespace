{
  "name": "@visualtools/namespace",
  "version": "1.1.1",
  "description": "Dotted-path namespace utilities for JavaScript — 8-verb point-contract API, path algebra, and batch contracts",
  "main": "dist/namespace.cjs",
  "module": "dist/namespace.mjs",
  "browser": "dist/namespace.umd.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.ts",
        "default": "./dist/namespace.mjs"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./dist/namespace.cjs"
      }
    },
    "./browser": {
      "default": "./dist/namespace.umd.js"
    }
  },
  "files": [
    "dist/",
    "types/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "test": "node --test test/*.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "namespace",
    "dotted-path",
    "object-path",
    "auto-vivification",
    "deep-get",
    "deep-set",
    "nested-objects",
    "configuration",
    "zero-dependency"
  ],
  "author": "Christopher Reay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christopherreay/node-namespace.git"
  },
  "bugs": {
    "url": "https://github.com/christopherreay/node-namespace/issues"
  },
  "homepage": "https://github.com/christopherreay/node-namespace#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {}
}
